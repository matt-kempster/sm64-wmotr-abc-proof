}
Local writes usually do not matter for global preservation, but they matter for sequential semantics.

4. The extractor skeleton
A real V0 can be built with Clang tooling. The simplest shape is:

from clang import cindex
from dataclasses import dataclass, asdict
import json

WRITE_KINDS = {
    cindex.CursorKind.BINARY_OPERATOR,
    cindex.CursorKind.COMPOUND_ASSIGNMENT_OPERATOR,
    cindex.CursorKind.UNARY_OPERATOR,
    cindex.CursorKind.CALL_EXPR,
}

def tokens(cursor):
    return [t.spelling for t in cursor.get_tokens()]

def source_span(cursor):
    loc = cursor.extent.start
    end = cursor.extent.end
    return {
        "file": str(loc.file),
        "line_start": loc.line,
        "col_start": loc.column,
        "line_end": end.line,
        "col_end": end.column,
    }

def strip_parens_and_casts(cur):
    # Implement by descending through implicit casts / parens in libclang
    # or by using clang AST JSON where these nodes are explicit.
    return cur

def sizeof_type(t):
    try:
        return t.get_size()
    except Exception:
        return None

def classify_lvalue(cur):
    cur = strip_parens_and_casts(cur)

    if cur.kind == cindex.CursorKind.DECL_REF_EXPR:
        decl = cur.referenced
        if decl.semantic_parent.kind == cindex.CursorKind.TRANSLATION_UNIT:
            return {
                "kind": "global",
                "symbol": cur.spelling,
                "bytes": sizeof_type(cur.type),
                "ctype": cur.type.spelling,
            }
        else:
            return {
                "kind": "local",
                "name": cur.spelling,
                "bytes": sizeof_type(cur.type),
                "ctype": cur.type.spelling,
            }

    if cur.kind == cindex.CursorKind.UNARY_OPERATOR:
        toks = tokens(cur)
        if toks and toks[0] == "*":
            child = list(cur.get_children())[0]
            return {
                "kind": "deref",
                "expr": " ".join(tokens(child)),
                "bytes": sizeof_type(cur.type),
                "ctype": cur.type.spelling,
            }

    if cur.kind == cindex.CursorKind.MEMBER_REF_EXPR:
        # Need: base expression, field name, offset.
        # Offset comes from generated layout, not manual data.
        return {
            "kind": "field",
            "field": cur.spelling,
            "base": "TODO: classify base expression",
            "offset": "generated_from_layout",
            "bytes": sizeof_type(cur.type),
            "ctype": cur.type.spelling,
        }

    return {
        "kind": "unknown_lvalue",
        "expr": " ".join(tokens(cur)),
        "havoc": "all"
    }

def extract_call(cur):
    children = list(cur.get_children())
    callee = children[0] if children else None

    if callee and callee.kind == cindex.CursorKind.DECL_REF_EXPR:
        return {
            "kind": "call",
            "callee": callee.spelling,
            "source": source_span(cur),
        }

    return {
        "kind": "unknown_call",
        "callee_expr": " ".join(tokens(callee)) if callee else None,
        "effect": "havoc_all",
        "source": source_span(cur),
    }

def extract_stmt(cur):
    out = []

    if cur.kind == cindex.CursorKind.BINARY_OPERATOR:
        toks = tokens(cur)
        if "=" in toks:
            children = list(cur.get_children())
            lhs = children[0]
            rhs = children[1]
            out.append({
                "kind": "store",
                "lhs": classify_lvalue(lhs),
                "rhs": " ".join(tokens(rhs)),
                "source": source_span(cur),
            })

    elif cur.kind == cindex.CursorKind.CALL_EXPR:
        out.append(extract_call(cur))

    for child in cur.get_children():
        out.extend(extract_stmt(child))

    return out

def extract_functions(tu):
    functions = []
    for cur in tu.cursor.get_children():
        if cur.kind == cindex.CursorKind.FUNCTION_DECL and cur.is_definition():
            body_events = []
            for child in cur.get_children():
                body_events.extend(extract_stmt(child))

            functions.append({
                "function": cur.spelling,
                "return_type": cur.result_type.spelling,
                "source": source_span(cur),
                "events": body_events,
            })
    return functions

index = cindex.Index.create()
tu = index.parse(
    "src/game/shadow.c",
    args=[
        "-Iinclude",
        "-Isrc",
        "-DVERSION_US",
        # plus the real flags from compile_commands.json
    ],
)

print(json.dumps(extract_functions(tu), indent=2))
That is not a complete extractor, but it shows the mechanism. The important point: the JSON is produced by walking AST assignments/calls, not written by us.

5. Field offsets must also be generated
A subtle point: do not manually encode offsets like Shadow.floorHeight = 12.

Generate layout from the compiler frontend.

Options:

clang -Xclang -fdump-record-layouts
or, better, use the same compile configuration and emit a layout manifest:

{
  "struct Shadow": {
    "sizeof": 44,
    "fields": {
      "parentX": { "offset": 0, "bytes": 4 },
      "parentY": { "offset": 4, "bytes": 4 },
      "parentZ": { "offset": 8, "bytes": 4 },
      "floorHeight": { "offset": 12, "bytes": 4 }
    }
  }
}
For the real SM64 proof, this has to respect the target ABI/layout, not the host machine’s layout. For shadow.c V0, Clang layout is probably fine as a smoke test; for the real ROM-facing project, layout should be generated from the exact target configuration/build artifacts.

