def scale_shadow_with_distance_ir (initial distFromFloor : F32) : F32 :=
  if distFromFloor <= 0.0 then
    initial
  else if distFromFloor >= 600.0 then
    initial * 0.5
  else
    initial * (1.0 - (0.5 * distFromFloor / 600.0))
